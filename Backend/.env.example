# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Copy to .env and fill in real values.
# NEVER commit .env to version control.
# ─────────────:──────────────────────────────────────────────────────────────

# ── Environment ──────────────────────────────────────────────────────────────
ENVIRONMENT=development        # development | production

# ── MySQL ─────────────────────────────────────────────────────────────────────
DATABASE_URL=mysql+pymysql://root:YOUR_DB_PASSWORD@localhost:3307/learning_db

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URL=mongodb://localhost:27017/chat_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_STRONG_RANDOM_SECRET
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
COOKIE_SECURE=false            # Set true when behind HTTPS in production

# ── AI APIs ───────────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=your_deepseek_key_here
DEEPSEEK_MODEL=deepseek/deepseek-v4-flash
USE_DEEPSEEK=true
GEMINI_API_KEY=

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Leave MAIL_SERVER empty to disable email (app still works without it).
# Gmail example: server=smtp.gmail.com, port=587, starttls=true, ssl=false
# Use an App Password (not your main Gmail password) if using Gmail with 2FA.
MAIL_SERVER=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_FROM_NAME=AI Learning Assistant
MAIL_STARTTLS=true
MAIL_SSL_TLS=false

# ── Cloudinary ────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── CORS ──────────────────────────────────────────────────────────────────────
# JSON list of allowed origins (comma-separated in some setups).
# Defaults defined in config.py are sufficient for local dev.
# BACKEND_CORS_ORIGINS=["https://your-frontend-domain.com"]
