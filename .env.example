# =========================================================================
# CẤU HÌNH BIẾN MÔI TRƯỜNG MẪU (AI Learning Assistant Platform)
# Hướng dẫn: Tạo file .env từ file này và điền các giá trị thực tế của bạn.
# =========================================================================

# 1. Gemini LLM API Key (Bắt buộc cho AI Core hoạt động)
GEMINI_API_KEY=your_gemini_api_key_here

# 2. OpenAI API Key (Tùy chọn, dùng nếu bạn muốn cấu hình thêm model OpenAI)
OPENAI_API_KEY=your_openai_api_key_here

# 3. Cấu hình bảo mật JWT Token (Backend)
# Gợi ý: Chạy lệnh `openssl rand -hex 32` để tạo mã bảo mật ngẫu nhiên
SECRET_KEY=9a15f9b4c8038e2d42dcfb87b7a13c9e6e4f1a2b3c4d5e6f7a8b9c0d1e2f3a4b
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=11520

# 4. Cấu hình kết nối DB khi chạy LOCAL (Không qua Docker)
# Dùng để chạy test/debug trực tiếp trên máy host
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/learning_db
MONGODB_URL=mongodb://localhost:27017/chat_db
REDIS_URL=redis://localhost:6379/0

# Lưu ý: Khi chạy bằng Docker, các biến kết nối database sẽ tự động được 
# docker-compose override để kết nối trực tiếp qua mạng nội bộ container
# (ví dụ: host localhost sẽ tự động chuyển thành db, mongodb, redis).
